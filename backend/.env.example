# Copy this file to `.env` and fill in real values. NEVER commit real secrets.
# The local `.env` takes precedence over `.env.<NODE_ENV>`.

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
API_PREFIX=api
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info
SWAGGER_ENABLED=true

# ── Database (MongoDB) ───────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=dmc_crm

# ── AI provider (Groq). AI endpoints are disabled if GROQ_API_KEY is unset ─────
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
# Reasoning models (Qwen3, gpt-oss): 'none' disables thinking (required for JSON mode).
# Use 'auto' to omit the param for non-reasoning models (e.g. Llama).
GROQ_REASONING_EFFORT=none

# ── API gate. When set, all routes except /health require the x-api-key header ─
API_KEY=

# ── Redis (used by queues/health when those modules are enabled) ─────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── JWT (auth scaffold; use 32+ char secrets) ────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-32+character-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-a-32+character-random-secret
JWT_REFRESH_TTL=7d

# ── Auth policy (account lockout & password reset) ───────────────────────────
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_REFRESH_TTL_DAYS=7
AUTH_RESET_TOKEN_TTL_MINUTES=30

# ── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ── Catalog seed bootstrap (npm run seed:catalog) — CHANGE before production ──
SEED_ORG_NAME=Default DMC
SEED_ORG_SLUG=default-dmc
SEED_SUPERADMIN_EMAIL=superadmin@dmc.local
SEED_SUPERADMIN_PASSWORD=ChangeMe123!
SEED_OWNER_EMAIL=owner@dmc.local
SEED_OWNER_PASSWORD=ChangeMe123!
